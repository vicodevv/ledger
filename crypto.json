{
  "info": {
    "_postman_id": "ledger-crypto-collection",
    "name": "Ledger API - Crypto Module",
    "description": "Blockchain integration tests for crypto wallet monitoring and balance tracking",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "tenant_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "crypto_wallet_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "crypto_eth_account_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "customer_deposit_account_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Setup - Create Crypto Accounts",
      "item": [
        {
          "name": "Create Crypto Asset Account (ETH)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('crypto_eth_account_id', response.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantId\": \"{{tenant_id}}\",\n  \"code\": \"CRYPTO_ETH\",\n  \"name\": \"Ethereum Holdings\",\n  \"type\": \"ASSET\",\n  \"currency\": \"USD\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/accounts",
              "host": ["{{base_url}}"],
              "path": ["accounts"]
            }
          }
        },
        {
          "name": "Create Customer Deposit Account",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('customer_deposit_account_id', response.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantId\": \"{{tenant_id}}\",\n  \"code\": \"CUSTOMER_DEPOSIT\",\n  \"name\": \"Customer Crypto Deposits\",\n  \"type\": \"LIABILITY\",\n  \"currency\": \"USD\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/accounts",
              "host": ["{{base_url}}"],
              "path": ["accounts"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Wallet Management",
      "item": [
        {
          "name": "Create Wallet (Vitalik)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('crypto_wallet_id', response.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantId\": \"{{tenant_id}}\",\n  \"address\": \"0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045\",\n  \"network\": \"ETHEREUM\",\n  \"label\": \"Vitalik Test Wallet\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/crypto/wallets",
              "host": ["{{base_url}}"],
              "path": ["crypto", "wallets"]
            }
          }
        },
        {
          "name": "Get All Wallets",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/crypto/wallets",
              "host": ["{{base_url}}"],
              "path": ["crypto", "wallets"]
            }
          }
        },
        {
          "name": "Get Wallet by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/crypto/wallets/{{crypto_wallet_id}}",
              "host": ["{{base_url}}"],
              "path": ["crypto", "wallets", "{{crypto_wallet_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "3. Balances",
      "item": [
        {
          "name": "Get ETH Balance",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/crypto/wallets/{{crypto_wallet_id}}/balance?asset=ETH",
              "host": ["{{base_url}}"],
              "path": ["crypto", "wallets", "{{crypto_wallet_id}}", "balance"],
              "query": [
                {
                  "key": "asset",
                  "value": "ETH"
                }
              ]
            }
          }
        },
        {
          "name": "Get USDC Balance",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/crypto/wallets/{{crypto_wallet_id}}/balance?asset=USDC",
              "host": ["{{base_url}}"],
              "path": ["crypto", "wallets", "{{crypto_wallet_id}}", "balance"],
              "query": [
                {
                  "key": "asset",
                  "value": "USDC"
                }
              ]
            }
          }
        },
        {
          "name": "Get All Balances",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/crypto/wallets/{{crypto_wallet_id}}/balances",
              "host": ["{{base_url}}"],
              "path": ["crypto", "wallets", "{{crypto_wallet_id}}", "balances"]
            }
          }
        }
      ]
    },
    {
      "name": "4. Transactions",
      "item": [
        {
          "name": "Get Transactions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/crypto/wallets/{{crypto_wallet_id}}/transactions",
              "host": ["{{base_url}}"],
              "path": ["crypto", "wallets", "{{crypto_wallet_id}}", "transactions"]
            }
          }
        },
        {
          "name": "Sync Wallet",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/crypto/wallets/{{crypto_wallet_id}}/sync",
              "host": ["{{base_url}}"],
              "path": ["crypto", "wallets", "{{crypto_wallet_id}}", "sync"]
            }
          }
        },
        {
          "name": "Record Deposit",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"walletId\": \"{{crypto_wallet_id}}\",\n  \"txHash\": \"0x1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef\",\n  \"asset\": \"ETH\",\n  \"amount\": 0.5\n}"
            },
            "url": {
              "raw": "{{base_url}}/crypto/deposits",
              "host": ["{{base_url}}"],
              "path": ["crypto", "deposits"]
            }
          }
        }
      ]
    }
  ]
}