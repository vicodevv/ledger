            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantId\": \"{{tenant_id}}\",\n  \"code\": \"4000\",\n  \"name\": \"Sales Revenue\",\n  \"type\": \"REVENUE\",\n  \"currency\": \"NGN\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/accounts",
              "host": ["{{base_url}}"],
