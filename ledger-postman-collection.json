        {
          "name": "Create Expense Account",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantId\": \"{{tenant_id}}\",\n  \"code\": \"5000\",\n  \"name\": \"Operating Expenses\",\n  \"type\": \"EXPENSE\",\n  \"currency\": \"NGN\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/accounts",
              "host": ["{{base_url}}"],
              "path": ["accounts"]
