{
  "info": {
    "_postman_id": "ledger-api-collection",
    "name": "Ledger API - Complete Collection",
    "description": "Production-grade double-entry accounting ledger with multi-tenant support, multi-currency handling, exchange rates, and audit logging.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "tenant_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "cash_account_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "revenue_account_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "transaction_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Tenants",
      "item": [
        {
          "name": "Create Tenant",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('tenant_id', response.id);",
                  "    pm.environment.set('tenant_id', response.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Corporation\",\n  \"slug\": \"acme\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/tenants",
              "host": ["{{base_url}}"],
              "path": ["tenants"]
            },
            "description": "Creates a new tenant (company) in the system. Each tenant has isolated data."
          },
          "response": []
        },
        {
          "name": "Get All Tenants",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tenants",
              "host": ["{{base_url}}"],
              "path": ["tenants"]
            },
            "description": "Retrieves all tenants in the system."
          },
          "response": []
        },
        {
          "name": "Get Tenant by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tenants/{{tenant_id}}",
              "host": ["{{base_url}}"],
              "path": ["tenants", "{{tenant_id}}"]
            },
            "description": "Retrieves a specific tenant by ID."
          },
          "response": []
        },
        {
          "name": "Get Tenant by Slug",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tenants/slug/acme",
              "host": ["{{base_url}}"],
              "path": ["tenants", "slug", "acme"]
            },
            "description": "Retrieves a tenant by their unique slug."
          },
          "response": []
        },
        {
          "name": "Delete Tenant",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tenants/{{tenant_id}}",
              "host": ["{{base_url}}"],
              "path": ["tenants", "{{tenant_id}}"]
            },
            "description": "Deletes a tenant and all associated data."
          },
          "response": []
        }
      ],
      "description": "Tenant management endpoints for multi-tenant isolation."
    },
    {
