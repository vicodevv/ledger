              "raw": "{{base_url}}/audit",
              "host": ["{{base_url}}"],
              "path": ["audit"]
            },
            "description": "Retrieves all audit logs (limited to last 100)."
          },
          "response": []
        },
        {
          "name": "Get Audit Logs by Tenant",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/audit/tenant/{{tenant_id}}",
              "host": ["{{base_url}}"],
              "path": ["audit", "tenant", "{{tenant_id}}"]
            },
            "description": "Retrieves audit logs for a specific tenant."
          },
          "response": []
        },
        {
          "name": "Get Audit History for Entity",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/audit/entity/transaction/{{transaction_id}}",
              "host": ["{{base_url}}"],
              "path": ["audit", "entity", "transaction", "{{transaction_id}}"]
            },
            "description": "Gets complete audit history for a specific entity (e.g., a transaction)."
          },
          "response": []
        },
        {
          "name": "Get Activity Summary",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/audit/summary/{{tenant_id}}?days=7",
              "host": ["{{base_url}}"],
              "path": ["audit", "summary", "{{tenant_id}}"],
              "query": [
                {
                  "key": "days",
                  "value": "7"
                }
              ]
            },
            "description": "Gets activity summary (creates/updates/deletes) for the last N days."
          },
          "response": []
        },
        {
          "name": "Filter Audit Logs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/audit?tenantId={{tenant_id}}&entityType=transaction&startDate=2026-04-01&endDate=2026-04-30",
              "host": ["{{base_url}}"],
              "path": ["audit"],
              "query": [
                {
                  "key": "tenantId",
                  "value": "{{tenant_id}}"
                },
                {
                  "key": "entityType",
                  "value": "transaction"
                },
                {
                  "key": "startDate",
                  "value": "2026-04-01"
                },
                {
                  "key": "endDate",
                  "value": "2026-04-30"
                }
              ]
            },
            "description": "Filters audit logs by tenant, entity type, and date range."
          },
          "response": []
        },
        {
          "name": "Create Manual Audit Log",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantId\": \"{{tenant_id}}\",\n  \"entityType\": \"account\",\n  \"entityId\": \"{{cash_account_id}}\",\n  \"action\": \"UPDATE\",\n  \"performedBy\": \"user-123\",\n  \"changes\": {\n    \"before\": { \"name\": \"Cash\" },\n    \"after\": { \"name\": \"Cash in Bank\" }\n  },\n  \"ipAddress\": \"192.168.1.1\",\n  \"userAgent\": \"PostmanRuntime/7.32.0\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/audit",
              "host": ["{{base_url}}"],
              "path": ["audit"]
            },
            "description": "Manually creates an audit log (usually auto-logged by other modules)."
          },
          "response": []
        }
      ],
      "description": "Complete audit trail tracking all system actions."
    }
  ],
  "auth": {
    "type": "noauth"
  },
  "event": []
}
