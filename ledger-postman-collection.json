        {
          "name": "Delete Account",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/accounts/{{cash_account_id}}",
              "host": ["{{base_url}}"],
              "path": ["accounts", "{{cash_account_id}}"]
            },
            "description": "Deletes an account. Will fail if account has children or transactions."
          },
          "response": []
        }
      ],
      "description": "Chart of accounts management with support for account hierarchies."
    },
    {
      "name": "3. Transactions (Ledger)",
      "item": [
        {
          "name": "Create Transaction - Customer Payment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('transaction_id', response.id);",
                  "    pm.environment.set('transaction_id', response.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantId\": \"{{tenant_id}}\",\n  \"idempotencyKey\": \"payment-001\",\n  \"description\": \"Payment from customer\",\n  \"reference\": \"INV-001\",\n  \"transactionDate\": \"2026-04-30T10:00:00Z\",\n  \"createdBy\": \"user-123\",\n  \"lines\": [\n    {\n      \"accountId\": \"{{cash_account_id}}\",\n      \"debit\": 10000,\n      \"credit\": 0,\n      \"currency\": \"NGN\",\n      \"description\": \"Cash received\"\n    },\n    {\n      \"accountId\": \"{{revenue_account_id}}\",\n      \"debit\": 0,\n      \"credit\": 10000,\n      \"currency\": \"NGN\",\n      \"description\": \"Sales revenue\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/transactions",
              "host": ["{{base_url}}"],
              "path": ["transactions"]
            },
            "description": "Creates a double-entry transaction. Debits must equal credits. Example: Customer pays ₦10,000."
          },
          "response": []
        },
        {
          "name": "Create Transaction - Expense Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantId\": \"{{tenant_id}}\",\n  \"idempotencyKey\": \"expense-001\",\n  \"description\": \"Office rent payment\",\n  \"reference\": \"RENT-APR-2026\",\n  \"transactionDate\": \"2026-04-30T10:00:00Z\",\n  \"createdBy\": \"user-123\",\n  \"lines\": [\n    {\n      \"accountId\": \"EXPENSE_ACCOUNT_ID_HERE\",\n      \"debit\": 5000,\n      \"credit\": 0,\n      \"currency\": \"NGN\",\n      \"description\": \"Rent expense\"\n    },\n    {\n      \"accountId\": \"{{cash_account_id}}\",\n      \"debit\": 0,\n      \"credit\": 5000,\n      \"currency\": \"NGN\",\n      \"description\": \"Cash payment\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/transactions",
              "host": ["{{base_url}}"],
              "path": ["transactions"]
            },
            "description": "Creates an expense transaction. Cash decreases, Expense increases."
          },
          "response": []
        },
        {
          "name": "Test Idempotency - Duplicate Transaction",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantId\": \"{{tenant_id}}\",\n  \"idempotencyKey\": \"payment-001\",\n  \"description\": \"Duplicate attempt\",\n  \"reference\": \"INV-001\",\n  \"transactionDate\": \"2026-04-30T10:00:00Z\",\n  \"lines\": [\n    {\n      \"accountId\": \"{{cash_account_id}}\",\n      \"debit\": 10000,\n      \"credit\": 0,\n      \"currency\": \"NGN\"\n    },\n    {\n      \"accountId\": \"{{revenue_account_id}}\",\n      \"debit\": 0,\n      \"credit\": 10000,\n      \"currency\": \"NGN\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/transactions",
              "host": ["{{base_url}}"],
              "path": ["transactions"]
            },
            "description": "Tests idempotency - should return the existing transaction instead of creating a new one."
          },
          "response": []
        },
        {
          "name": "Test Validation - Unbalanced Transaction",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantId\": \"{{tenant_id}}\",\n  \"description\": \"This should fail - unbalanced\",\n  \"transactionDate\": \"2026-04-30T10:00:00Z\",\n  \"lines\": [\n    {\n      \"accountId\": \"{{cash_account_id}}\",\n      \"debit\": 5000,\n      \"credit\": 0,\n      \"currency\": \"NGN\"\n    },\n    {\n      \"accountId\": \"{{revenue_account_id}}\",\n      \"debit\": 0,\n      \"credit\": 3000,\n      \"currency\": \"NGN\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/transactions",
              "host": ["{{base_url}}"],
              "path": ["transactions"]
            },
            "description": "Tests validation - should fail because debits (5000) != credits (3000)."
          },
          "response": []
        },
        {
          "name": "Get All Transactions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/transactions",
              "host": ["{{base_url}}"],
              "path": ["transactions"]
            },
            "description": "Retrieves all transactions with their lines."
          },
          "response": []
        },
        {
          "name": "Get Transactions by Tenant",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/transactions?tenantId={{tenant_id}}",
              "host": ["{{base_url}}"],
              "path": ["transactions"],
              "query": [
                {
                  "key": "tenantId",
                  "value": "{{tenant_id}}"
                }
              ]
            },
            "description": "Retrieves all transactions for a specific tenant."
          },
          "response": []
        },
        {
          "name": "Get Transaction by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/transactions/{{transaction_id}}",
              "host": ["{{base_url}}"],
              "path": ["transactions", "{{transaction_id}}"]
            },
            "description": "Retrieves a specific transaction with all its lines."
          },
          "response": []
        }
      ],
      "description": "Double-entry transaction engine with automatic balance updates."
    },
    {
      "name": "4. Exchange Rates",
      "item": [
        {
          "name": "Sync Rates from API",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/exchange-rates/sync",
              "host": ["{{base_url}}"],
              "path": ["exchange-rates", "sync"]
            },
            "description": "Manually triggers exchange rate sync from external API. Auto-syncs daily at midnight."
          },
          "response": []
        },
        {
          "name": "Create Manual Exchange Rate",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fromCurrency\": \"USD\",\n  \"toCurrency\": \"NGN\",\n  \"rate\": 1580.50,\n  \"validFrom\": \"2026-04-30T00:00:00Z\",\n  \"source\": \"manual\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/exchange-rates",
              "host": ["{{base_url}}"],
              "path": ["exchange-rates"]
            },
            "description": "Manually creates an exchange rate (e.g., for custom or historical rates)."
          },
          "response": []
        },
        {
          "name": "Get All Exchange Rates",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/exchange-rates",
              "host": ["{{base_url}}"],
              "path": ["exchange-rates"]
            },
            "description": "Retrieves all exchange rates (historical and current)."
          },
          "response": []
        },
        {
          "name": "Get Latest Rate for Currency Pair",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/exchange-rates/latest?from=USD&to=NGN",
              "host": ["{{base_url}}"],
              "path": ["exchange-rates", "latest"],
              "query": [
                {
                  "key": "from",
                  "value": "USD"
                },
                {
                  "key": "to",
                  "value": "NGN"
                }
              ]
            },
            "description": "Gets the most recent exchange rate for a currency pair."
          },
          "response": []
        },
        {
          "name": "Get Rate at Specific Date",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/exchange-rates/rate?from=USD&to=NGN&date=2026-04-30",
              "host": ["{{base_url}}"],
              "path": ["exchange-rates", "rate"],
              "query": [
                {
                  "key": "from",
                  "value": "USD"
                },
                {
                  "key": "to",
                  "value": "NGN"
                },
                {
                  "key": "date",
                  "value": "2026-04-30"
                }
              ]
            },
            "description": "Gets the exchange rate for a currency pair at a specific date."
          },
          "response": []
        },
        {
          "name": "Convert Currency",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/exchange-rates/convert?amount=100&from=USD&to=NGN",
              "host": ["{{base_url}}"],
              "path": ["exchange-rates", "convert"],
              "query": [
                {
                  "key": "amount",
                  "value": "100"
                },
                {
                  "key": "from",
                  "value": "USD"
                },
                {
                  "key": "to",
                  "value": "NGN"
                }
              ]
            },
            "description": "Converts an amount from one currency to another using current rates."
          },
          "response": []
        },
        {
          "name": "Test Reverse Rate Calculation",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/exchange-rates/rate?from=NGN&to=USD",
              "host": ["{{base_url}}"],
              "path": ["exchange-rates", "rate"],
              "query": [
                {
                  "key": "from",
                  "value": "NGN"
                },
                {
                  "key": "to",
                  "value": "USD"
                }
              ]
            },
            "description": "Tests automatic reverse rate calculation (if USD/NGN exists, calculates NGN/USD)."
          },
          "response": []
        }
      ],
      "description": "Multi-currency support with auto-sync from external APIs."
    },
    {
      "name": "5. Audit Logs",
      "item": [
        {
          "name": "Get All Audit Logs",
          "request": {
            "method": "GET",
            "header": [],
