          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantId\": \"{{tenant_id}}\",\n  \"code\": \"1000\",\n  \"name\": \"Cash in Bank\",\n  \"type\": \"ASSET\",\n  \"currency\": \"NGN\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/accounts",
              "host": ["{{base_url}}"],
              "path": ["accounts"]
            },
            "description": "Creates a Cash account (ASSET type). Account types: ASSET, LIABILITY, EQUITY, REVENUE, EXPENSE."
          },
          "response": []
        },
